 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;Hermes&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;研究级记忆架构&lt;/td&gt;
 &lt;td&gt;自建&lt;/td&gt;
 &lt;td&gt;分层记忆、主动巩固、元认知&lt;/td&gt;
 &lt;td&gt;研究/高要求生产环境&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
